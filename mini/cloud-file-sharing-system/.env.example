# ================================
# FLASK CONFIGURATION
# ================================
SECRET_KEY=your_secret_key_here_change_in_production

# ================================
# STORAGE CONFIGURATION
# ================================
# Choose storage type: local, gcs, s3, or azure
STORAGE_TYPE=local

# ------
# LOCAL STORAGE (default)
# ------
# No additional configuration needed, files will be stored in ./uploads/

# ------
# GOOGLE CLOUD STORAGE (GCS)
# ------
# STORAGE_TYPE=gcs
# GCS_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ------
# AWS S3
# ------
# STORAGE_TYPE=s3
# AWS_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ------
# AZURE BLOB STORAGE
# ------
# STORAGE_TYPE=azure
# AZURE_CONTAINER=your-container-name
# AZURE_ACCOUNT_NAME=your-account-name
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# OR
# AZURE_STORAGE_KEY=your-storage-key

# ================================
# EMAIL/SMTP CONFIGURATION (for OTP)
# ================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ================================
# FILE UPLOAD SETTINGS
# ================================
# Maximum file size: 1GB (1073741824 bytes)
# Supports: videos, audio, documents, images, and more
# No file type restrictions

# ================================
# FEATURES
# ================================
# - File size tracking (displayed in files list)
# - MIME type tracking (automatic detection)
# - Media duration extraction (for audio/video files - requires ffprobe)
# - Chunked upload support (for large files)
# - Download counter
# - OTP-based login with email verification
